{
  "name": "image-resizer-react-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "dev:lan": "vite --host --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "predeploy": "npm ci && npm run build",
    "deploy": "git push",
    "check:deps": "npm outdated",
    "update:deps": "npm update && npm run check:deps",
    "setup:hooks": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "fabric": "^5.5.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.9.0",
    "opentype.js": "^1.3.4",
    "piexifjs": "^1.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.31",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
